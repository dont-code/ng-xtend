{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "preserve",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "paths": {
      "xt-type": ["../libs/xt-type/src/index.ts"],
      "xt-type/browser": ["../libs/xt-type/src/browser.ts"],
      "xt-components": ["../libs/xt-components/projects/xt-components/src/public-api.ts"],
      "xt-store": ["../libs/xt-store/projects/store/src/public-api.ts"]
    }
  },
  "include": ["./api-entrypoints/*.ts"]
}
