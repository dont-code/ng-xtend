{
  "name": "xt-store",
  "version": "0.7.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build-deploy": "APP=store && ng build $APP --configuration=$BUILD",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "publishConfig": {
    "directory": "dist/store",
    "linkDirectory": true
  },
  "repository": {
    "url": "https://github.com/dont-code/ng-xtend.git"
  },
  "private": false,
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@angular/router": "^21.2.7",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "@ngrx/signals": "^21.1.0",
    "xt-type": "workspace:^"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "happy-dom": "^20.8.9",
    "ng-packagr": "^21.2.2",
    "typescript": "^5.9.3",
    "@types/node": "^24.12.2",
    "jsdom": "^29.0.1",
    "vitest": "^4.1.2"
  }
}
