{
  "name": "xt-idb-store",
  "version": "0.6.4",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration=development",
    "build-deploy": "APP=idb-store && ng build $APP --configuration=$BUILD",
    "watch": "ng build --watch --configuration development",
    "test": "cd projects/idb-store && ../../node_modules/.bin/vitest"
  },
  "private": false,
  "publishConfig": {
    "directory": "dist/store",
    "linkDirectory": true
  },
  "repository": {
    "url": "https://github.com/dont-code/ng-xtend.git"
  },
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/router": "^21.2.7",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "@ngrx/signals": "^21.1.0",
    "xt-type": "workspace:^",
    "xt-store": "workspace:^",
    "dexie": "~4.0.11",
    "fake-indexeddb": "~6.0.0",
    "core-js": "^3.40.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@analogjs/vite-plugin-angular": "^2.4.0",
    "@analogjs/vitest-angular": "^2.4.0",
    "jsdom": "^29.0.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "happy-dom": "^20.8.9",
    "ng-packagr": "^21.2.2",
    "typescript": "^5.9.3"
  }
